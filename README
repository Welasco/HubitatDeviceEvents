Get Device List Version Details

$devices = Invoke-RestMethod http://hubitat.localdomain/hub2/devicesList
$dList = $devices.devices.data | ?{($_.type -like "Generic *") -or ($_.type -like "GE *")} | select name, type, id

$TemplateObject = New-Object PSObject | Select-Object CreateTime,LastUpdatedTime,Name,Type,Id,firmwareVersion,hardwareVersion,inClusters
$tempArr= New-Object System.Collections.ArrayList
$dList | %{
    $WorkingObject = $TemplateObject | Select-Object *
    $d = Invoke-RestMethod http://hubitat.localdomain/device/fullJson/$($_.id)
    $WorkingObject.CreateTime = $d.device.createTime
    $WorkingObject.LastUpdatedTime = $d.device.updateTime
    $WorkingObject.Name =  $_.name
    $WorkingObject.Type = $_.type
    $WorkingObject.Id = $_.id
    $WorkingObject.firmwareVersion = $d.device.data.firmwareVersion
    $WorkingObject.hardwareVersion = $d.device.data.hardwareVersion
    $WorkingObject.inClusters = $d.device.data.inClusters
    $tempArr.Add($WorkingObject) | Out-Null
}
#$tempArr | ft

$tempArr | sort LastUpdatedTime | ft




